# ══════════════════════════════════════════════════════════════════
#  TURIDOVE - Variables de entorno para Docker
#
#  DESARROLLO LOCAL: los valores por defecto funcionan tal cual.
#                    Solo copia este archivo a .env.docker y ejecuta setup.
#
#  PRODUCCIÓN: CAMBIA TODAS LAS VARIABLES MARCADAS CON !!!
# ══════════════════════════════════════════════════════════════════

# ─────────── PostgreSQL ───────────
POSTGRES_DB=turidove
POSTGRES_USER=postgres

# !!! PRODUCCIÓN: cambiar por contraseña fuerte
POSTGRES_PASSWORD=ServBay.dev

# Puerto externo en host (5433 para evitar conflicto con Postgres local)
# Si está ocupado, usa 5434 o cualquier otro libre
POSTGRES_PORT=5433

# ─────────── Backend ───────────
# !!! PRODUCCIÓN: generar con `openssl rand -base64 48` (mínimo 32 chars)
JWT_SECRET=change-this-in-production-to-a-long-random-string-min-32-chars

JWT_EXPIRATION=7d

# !!! PRODUCCIÓN: cambiar por el dominio del frontend
# Acepta múltiples dominios separados por coma:
# CORS_ORIGIN=https://turidove.com,https://www.turidove.com
CORS_ORIGIN=http://localhost:3000

# ─────────── Frontend ───────────
# IMPORTANTE: esta URL queda embebida en el build del frontend.
# Es llamada por el navegador del usuario (no por contenedores).
#
# !!! PRODUCCIÓN: cambiar por la URL pública HTTPS del backend
# Ejemplos:
#   NEXT_PUBLIC_API_URL=https://api.turidove.com/api/v1
#   NEXT_PUBLIC_API_URL=https://turidove.com/api/v1  (si usas mismo dominio + proxy)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Stripe (modo test por defecto - reemplazar en produccion)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLIC_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=http://localhost:3000/reservas/{RESERVA_ID}/pago/exito
STRIPE_CANCEL_URL=http://localhost:3000/reservas/{RESERVA_ID}/pago/cancelado
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_REPLACE_ME

# ─────────── Redis (BullMQ + cache rate limiting) ───────────
REDIS_PORT=6380
REDIS_PORT_INTERNAL=6379
REDIS_HOST=redis

# ─────────── Cookie security ───────────
# COOKIE_SECURE=true requires HTTPS to work in browsers.
# Set to false for local HTTP dev. In production set to true.
COOKIE_SECURE=false
